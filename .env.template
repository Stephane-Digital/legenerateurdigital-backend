# ----------------------------------------------------------
# 🧱 APPLICATION
# ----------------------------------------------------------
APP_ENV=production
APP_NAME="Le Générateur Digital API"
APP_VERSION=1.0.0
DEBUG=True
LOG_LEVEL=info

# ----------------------------------------------------------
# 🗄️ BASE DE DONNÉES (Render PostgreSQL ou locale)
# ----------------------------------------------------------
# Exemple Render :
# DATABASE_URL=postgresql://legenerateurdigital_db_user:password@hostname:5432/legenerateurdigital_db?sslmode=require
# Exemple local :
# DATABASE_URL=sqlite:///./prisma/dev.db
DATABASE_URL=postgresql://legenerateurdigital_db_user:password@hostname:5432/legenerateurdigital_db?sslmode=require

